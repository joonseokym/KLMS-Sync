# Copy this file to config.env for local use. Do not commit config.env.
# Optional: override python3 when /usr/bin/python3 is the Xcode shim.
# KLMS_PYTHON_BIN="/absolute/path/to/python3"
# KLMS_PYTHONPATH_DIR="/absolute/path/to/runtime/python-packages"
# Optional: point this at a shared overrides file if the LaunchAgent install runs from a copied directory.
# OVERRIDES_JSON_PATH="/absolute/path/to/manual_assignment_overrides.json"
